{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Backend (FastAPI or Flask)",
			"type": "shell",
			"command": "python -m backend.app.main",
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Run Frontend (Vite)",
			"type": "shell",
			"command": "cd frontend && npm run dev",
			"isBackground": true,
			"group": "build"
		}
	]
}